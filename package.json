{
  "name": "balloon-shoot-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "knip": "knip",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:replay": "vitest run --config vitest.replay.config.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "run-p lint typecheck test test:replay knip"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9.39.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "knip": "^6.4.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "knip": {
    "entry": ["index.html", "diagnostic.html", "src/diagnostic-main.ts"]
  }
}
